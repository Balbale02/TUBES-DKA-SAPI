# =============================================================================
# 1. MODUL MEMBERSHIP (Fungsi Keanggotaan & Praproses Data)
# =============================================================================

def trapezoid(x, a, b, c, d):
    """Fungsi keanggotaan Trapesium untuk mengubah input tegas ke derajat fuzzy."""
    x = np.asarray(x, dtype=float)
    y = np.zeros_like(x)
    mask1 = (x >= a) & (x < b)
    if b != a:
        y[mask1] = (x[mask1] - a) / (b - a)
    y[(x >= b) & (x <= c)] = 1.0
    mask3 = (x > c) & (x <= d)
    if d != c:
        y[mask3] = (d - x[mask3]) / (d - c)
    return y

def triangle(x, a, b, c):
    """Fungsi keanggotaan Segitiga untuk mengubah input tegas ke derajat fuzzy."""
    x = np.asarray(x, dtype=float)
    y = np.zeros_like(x)
    mask1 = (x >= a) & (x <= b)
    if b != a:
        y[mask1] = (x[mask1] - a) / (b - a)
    mask2 = (x > b) & (x <= c)
    if c != b:
        y[mask2] = (c - x[mask2]) / (c - b)
    y[x == b] = 1.0
    return y

def interp_membership(universe, mf_values, x):
    """Mendapatkan nilai derajat keanggotaan (y) berdasarkan nilai tegas (x)."""
    return float(np.interp(x, universe, mf_values))

def _load_and_preprocess(csv_path='zomato.csv'):
    """Memuat dataset Zomato dan membersihkan data kosong/rating nol."""
    try:
        df_raw = pd.read_csv(csv_path, encoding='latin-1')
    except FileNotFoundError:
        # Pengecualian dummy jika file tidak ditemukan saat pengujian mandiri
        print(f"File '{csv_path}' tidak ditemukan. Membuat data simulasi untuk testing...")
        np.random.seed(42)
        return pd.DataFrame({
            'Average Cost for two': np.random.randint(100, 2000, 500),
            'Votes': np.random.randint(10, 1000, 500),
            'Price range': np.random.randint(1, 5, 500),
            'Has Table booking': np.random.choice([1, 0], 500),
            'Has Online delivery': np.random.choice([1, 0], 500),
            'Aggregate rating': np.random.uniform(1.0, 4.9, 500)
        })

    cols = ['Restaurant Name', 'Average Cost for two', 'Price range',
            'Votes', 'Has Table booking', 'Has Online delivery', 'Aggregate rating']
    data_res = df_raw[cols].copy()
    data_res = data_res[data_res['Aggregate rating'] > 0]
    data_res['Has Table booking']   = data_res['Has Table booking'].map({'Yes': 1, 'No': 0})
    data_res['Has Online delivery'] = data_res['Has Online delivery'].map({'Yes': 1, 'No': 0})
    data_res = data_res.dropna().reset_index(drop=True)
    return data_res

def _get_breakpoints(series):
    """Menghitung batas kurva secara adaptif menggunakan kuartil data asli."""
    return {
        'min': float(series.min()),
        'p25': float(series.quantile(0.25)),
        'p50': float(series.quantile(0.50)),
        'p75': float(series.quantile(0.75)),
        'max': float(series.max()),
    }

