   "source": [
    "## 3. Sel Modul: `sugeno`\n",
    "Sel ini mengimplementasikan Metode Sugeno Orde-0. Metode ini menggantikan kurva area output dengan nilai konstanta tunggal (*singleton*), sehingga defuzzifikasinya jauh lebih cepat menggunakan rumus **Rata-rata Terbobot** (*Weighted Average*)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def weighted_average(fired_rules):\n",
    "    num = sum(r['firing_strength'] * r['output_value'] for r in fired_rules)\n",
    "    den = sum(r['firing_strength'] for r in fired_rules)\n",
    "    return num / den if den > 0 else 50.0\n",
    "\n",
    "def sugeno_predict(harga, votes, price_range, booking, delivery):\n",
    "    t0 = time.time()\n",
    "    fz = fuzzify_all(harga, votes, price_range, booking, delivery)\n",
    "    fired = []\n",
    "    for i, rule in enumerate(RULES):\n",
    "        strengths = [fz[var][lbl] for var, lbl in rule['conditions'] if lbl in fz.get(var, {})]\n",
    "        alpha = min(strengths) if strengths else 0.0\n",
    "        if alpha > 0:\n",
    "            z = SUGENO_CONSTANTS[rule['output']]\n",
    "            fired.append({\n",
    "                'rule_idx'       : i + 1,\n",
    "                'conditions'     : rule['conditions'],\n",
    "                'output'         : rule['output'],\n",
    "                'firing_strength': round(alpha, 4),\n",
    "                'output_value'   : z,\n",
    "            })\n",
    "    score = round(weighted_average(fired), 4) if fired else 50.0\n",
    "    return {\n",
    "        'score'      : score,\n",
    "        'level'      : get_rekomendasi_level(score),\n",
    "        'fired_rules': fired,\n",
    "        'runtime'    : round(time.time() - t0, 5),\n",
    "    }\n",
    "\n",
    "def sugeno_batch(df_input, sample_size=None):\n",
    "    df_s = df_input.sample(n=sample_size, random_state=42) if sample_size else df_input\n",
    "    actual, pred = [], []\n",
    "    for _, row in df_s.iterrows():\n",
    "        r = sugeno_predict(\n",
    "            row['Average Cost for two'], row['Votes'], row['Price range'],\n",
    "            row['Has Table booking'], row['Has Online delivery']\n",
    "        )\n",
    "        actual.append(row['Aggregate rating'] * 20)\n",
    "        pred.append(r['score'])\n",
    "    return np.array(actual), np.array(pred)\n",
    "\n",
    "print(\"Sel Modul Sugeno berhasil dimuat.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Sel Modul: `evaluasi_model`\n",
    "Sel terakhir ini mengevaluasi kinerja kedua sistem fuzzy di atas secara *batch* menggunakan 200 sampel data. Kinerjanya diukur berdasarkan tingkat kesalahan (metrik MAE, MSE, RMSE) serta kecepatan pemrosesan waktu (*runtime*)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def hitung_metrik_error(actual, predicted):\n",
    "    mae  = round(float(np.mean(np.abs(actual - predicted))), 4)\n",
    "    mse  = round(float(np.mean((actual - predicted) ** 2)), 4)\n",
    "    rmse = round(float(np.sqrt(mse)), 4)\n",
    "    return mae, mse, rmse\n",
    "\n",
    "N_SAMPEL = 200\n",
    "print(f\"Memulai kalkulasi pengujian batch pada {N_SAMPEL} sampel data...\")\n",
    "\n",
    "# Evaluasi Mamdani\n",
    "t_start_m = time.time()\n",
    "act_m, pred_m = mamdani_batch(_data, sample_size=N_SAMPEL)\n",
    "rt_m_batch = round(time.time() - t_start_m, 4)\n",
    "mae_m, mse_m, rmse_m = hitung_metrik_error(act_m, pred_m)\n",
    "\n",
    "# Evaluasi Sugeno\n",
    "t_start_s = time.time()\n",
    "act_s, pred_s = sugeno_batch(_data, sample_size=N_SAMPEL)\n",
    "rt_s_batch = round(time.time() - t_start_s, 4)\n",
    "mae_s, mse_s, rmse_s = hitung_metrik_error(act_s, pred_s)\n",
    "\n",
    "# Print Hasil Ringkasan\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"              HASIL EVALUASI KOMPARASI LOGIKA FUZZY\")\n",
    "print(\"=\"*60)\n",
    "print(f\" Metrik Performa    | Metode Mamdani       | Metode Sugeno\")\n",
    "print(\"-\"*60)\n",
    "print(f\" MAE                | {mae_m:<20} | {mae_s:<15}\")\n",
    "print(f\" MSE                | {mse_m:<20} | {mse_s:<15}\")\n",
    "print(f\" RMSE               | {rmse_m:<20} | {rmse_s:<15}\")\n",
    "print(f\" Batch Runtime      | {rt_m_batch:<17}s | {rt_s_batch:<12}s\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Kesimpulan: Kecepatan Sugeno berkisar {round(rt_m_batch/rt_s_batch, 2)}x lipat lebih cepat dibanding Mamdani.\")"
   ]
  }
 ],
